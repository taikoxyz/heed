{
  "name": "@heed/core",
  "version": "0.1.0",
  "description": "Heed core library: types, crypto, and chain utilities",
  "keywords": [
    "heed",
    "taiko",
    "ethereum",
    "messaging",
    "envelope",
    "wallet"
  ],
  "homepage": "https://github.com/taikoxyz/heed#readme",
  "bugs": {
    "url": "https://github.com/taikoxyz/heed/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taikoxyz/heed.git",
    "directory": "core-lib"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ciphers": "1.3.0",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "multiformats": "13.4.2",
    "viem": "2.48.4"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
