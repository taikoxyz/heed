{
  "name": "heed-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "core-lib",
    "web",
    "cli"
  ],
  "scripts": {
    "build:core": "npm --workspace @heed/core run build",
    "build:web": "npm --workspace @heed/web run build",
    "build:cli": "npm --workspace heed-cli run build",
    "test:core": "npm --workspace @heed/core run test",
    "test:web": "npm --workspace @heed/web run test",
    "test:cli": "npm --workspace heed-cli run test",
    "e2e": "bash scripts/e2e.sh",
    "e2e-fork": "bash scripts/e2e-fork.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,css,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "tsx": "4.21.0"
  }
}
